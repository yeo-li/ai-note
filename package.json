{
  "name": "ai-note",
  "version": "0.1.0",
  "private": true,
  "description": "Workspace root for the AI Note monorepo.",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev:desktop",
    "dev:desktop": "npm run dev --workspace @ai-note/desktop",
    "dev:server": "npm run dev --workspace @ai-note/server --if-present",
    "start": "npm run start --workspace @ai-note/desktop",
    "test": "npm run test --workspace @ai-note/desktop",
    "test:all": "npm run test --workspaces --if-present",
    "build": "npm run build:desktop",
    "build:desktop": "npm run build --workspace @ai-note/desktop",
    "build:server": "npm run build --workspace @ai-note/server --if-present",
    "build:renderer": "npm run build:renderer --workspace @ai-note/desktop",
    "test:e2e": "npm run test:e2e --workspace @ai-note/desktop",
    "test:e2e:smoke": "npm run test:e2e:smoke --workspace @ai-note/desktop",
    "test:e2e:visual": "npm run test:e2e:visual --workspace @ai-note/desktop",
    "test:e2e:headed": "npm run test:e2e:headed --workspace @ai-note/desktop",
    "test:e2e:update": "npm run test:e2e:update --workspace @ai-note/desktop",
    "test:e2e:report": "npm run test:e2e:report --workspace @ai-note/desktop",
    "allure:generate": "npm run allure:generate --workspace @ai-note/desktop",
    "allure:open": "npm run allure:open --workspace @ai-note/desktop",
    "allure:serve": "npm run allure:serve --workspace @ai-note/desktop",
    "dist:mac": "npm run dist:mac --workspace @ai-note/desktop",
    "dist:win": "npm run dist:win --workspace @ai-note/desktop"
  }
}
