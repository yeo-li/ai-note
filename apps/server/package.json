{
  "name": "@ai-note/server",
  "version": "0.1.0",
  "private": true,
  "dependencies": {
    "@ai-note/shared": "0.1.0"
  },
  "description": "TypeScript server workspace for the AI Note backend bootstrap.",
  "type": "module",
  "main": "dist/index.js",
  "engines": {
    "node": ">=20.12.0"
  },
  "scripts": {
    "dev": "tsx watch --clear-screen=false src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "test": "node --test --import tsx \"test/**/*.test.ts\""
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
